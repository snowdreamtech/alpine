{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "changelog-path": "CHANGELOG.md",
  "packages": {
    "docker/3.20": {
      "release-type": "simple",
      "component": "3.20"
    },
    "docker/3.21": {
      "release-type": "simple",
      "component": "3.21"
    },
    "docker/3.22": {
      "release-type": "simple",
      "component": "3.22"
    },
    "docker/3.23": {
      "release-type": "simple",
      "component": "3.23"
    }
  },
  "include-v-in-tag": true,
  "extra-files": [
    "*.csproj",
    "*.fsproj",
    "*.gemspec",
    "*.vbproj",
    "app.json",
    "appsettings.json",
    "bower.json",
    "build.gradle",
    "build.gradle.kts",
    "Cargo.lock",
    "Cargo.toml",
    "Chart.yaml",
    "CMakeLists.txt",
    "composer.json",
    "composer.lock",
    "deno.json",
    "deno.jsonc",
    "docker-compose.yaml",
    "docker-compose.yml",
    "Dockerfile",
    "Gemfile.lock",
    "go.mod",
    "gradle.properties",
    "kustomization.yaml",
    "lerna.json",
    "manifest.json",
    "mix.exs",
    "mkdocs.yml",
    "npm-shrinkwrap.json",
    "Package.swift",
    "package.json",
    "package-lock.json",
    "pnpm-lock.yaml",
    "pom.xml",
    "Project.toml",
    "pubspec.yaml",
    "pyproject.toml",
    "requirements.txt",
    "setup.py",
    "shard.yml",
    "sonar-project.properties",
    "VERSION",
    "yarn.lock"
  ],
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "pull-request-title-pattern": "chore(release): ${version} 🚀",
  "pull-request-header": "## 📦 Release Preparation\n\nThis PR was autogenerated by [release-please](https://github.com/googleapis/release-please). \n\n### ⚠️ Critical Actions Before Merging\n\n1. **Verify Quality**: Ensure all CI checks (Lint, Test, Security) are passing.\n2. **Review Changelog**: Confirm that the generated notes below accurately reflect the changes.\n3. **Sanity Check**: If this is a major version, verify that breaking changes are correctly documented.\n\nMerging this PR will create a GitHub Release and a Git Tag. 🚀",
  "changelog-sections": [
    {
      "type": "breaking",
      "section": "💥 BREAKING CHANGES",
      "hidden": false
    },
    {
      "type": "security",
      "section": "🛡️ Security Updates",
      "hidden": false
    },
    {
      "type": "sec",
      "section": "🛡️ Security Updates",
      "hidden": false
    },
    {
      "type": "feat",
      "section": "🚀 Features",
      "hidden": false
    },
    {
      "type": "fix",
      "section": "🐛 Bug Fixes",
      "hidden": false
    },
    {
      "type": "perf",
      "section": "⚡️ Performance Improvements",
      "hidden": false
    },
    {
      "type": "refactor",
      "section": "🛠 Refactoring",
      "hidden": false
    },
    {
      "type": "docs",
      "section": "📖 Documentation",
      "hidden": false
    },
    {
      "type": "chore",
      "section": "♻️ Miscellaneous Chores",
      "hidden": false
    }
  ],
  "separate-pull-requests": true
}
