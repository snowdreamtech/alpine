{
  "globs": [
    "**/*.md"
  ],
  "ignores": [
    ".git",
    "node_modules",
    ".venv",
    "venv",
    "env",
    "vendor",
    "dist",
    "build",
    "out",
    "target",
    ".next",
    ".nuxt",
    "__pycache__",
    ".specify",
    ".*/prompts/**/*.md",
    ".*/commands/**/*.md",
    ".*/agents/**/*.md",
    ".*/rules/rules.md",
    ".*/rules/project_rules.md",
    ".*/**/*.agent.md",
    ".*/**/*.prompt.md"
  ]
}
