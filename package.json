{
  "name": "snowdreamtech-template-docs",
  "version": "0.0.1",
  "private": true,
  "description": "VitePress documentation site for Snowdream Tech AI IDE Template",
  "scripts": {
    "archive-changelog": "sh scripts/archive-changelog.sh",
    "audit": "sh scripts/audit.sh",
    "bench": "sh scripts/bench.sh",
    "build": "sh scripts/build.sh",
    "check-env": "sh scripts/check-env.sh",
    "cleanup": "sh scripts/cleanup.sh",
    "commit": "sh scripts/commit.sh",
    "docs:build": "sh scripts/docs.sh build",
    "docs:dev": "sh scripts/docs.sh dev",
    "docs:preview": "sh scripts/docs.sh preview",
    "env": "sh scripts/env.sh",
    "format": "sh scripts/format.sh",
    "init": "sh scripts/init-project.sh",
    "install": "sh scripts/install.sh",
    "lint": "sh scripts/lint.sh",
    "release": "sh scripts/release.sh",
    "setup": "sh scripts/setup.sh",
    "sync-docs": "sh scripts/sync-docs.sh",
    "test": "sh scripts/test.sh",
    "update": "sh scripts/update.sh",
    "verify": "sh scripts/verify.sh"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.3",
    "@commitlint/config-conventional": "20.4.3",
    "@naturalcycles/ktlint": "1.16.1",
    "@stoplight/spectral-cli": "6.11.1",
    "@taplo/cli": "0.7.0",
    "bats": "1.13.0",
    "bats-assert": "2.2.4",
    "bats-support": "0.3.0",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "dockerfile-utils": "0.16.3",
    "eslint": "10.0.3",
    "markdownlint-cli2": "0.21.0",
    "prettier": "3.8.1",
    "sort-package-json": "3.6.1",
    "stylelint": "16.26.1",
    "stylelint-config-standard": "37.0.0",
    "vitepress": "1.6.4"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20.18.3"
  },
  "pnpm": {
    "overrides": {
      "@eslint/plugin-kit": "0.6.1",
      "esbuild": "0.27.3",
      "lodash": "4.17.23",
      "minimatch": "3.1.5",
      "rollup": "4.59.0",
      "tmp": "0.2.5"
    }
  }
