{
  "name": "Snowdream Tech Universal Workspace",
  "image": "ghcr.io/snowdreamtech/devcontainers:debian",
  "remoteUser": "root",
  "workspaceFolder": "/workspaces/template",
  "forwardPorts": [],
  "mounts": [
    "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gnupg,target=/root/.gnupg,type=bind,consistency=cached",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "containerEnv": {
    "ENABLE_GITHUB_PROXY": "0",
    "MISE_QUIET": "0",
    "GNUPGHOME": "/root/.gnupg"
  },
  "postCreateCommand": "mise trust -a && mise bootstrap && chmod 700 ~/.gnupg 2>/dev/null; git config --local user.signingkey \"$(git config --global user.signingkey)\" 2>/dev/null || true && git config --local commit.gpgsign true",
  "postStartCommand": "echo '✅ Devcontainer is ready!'"
}
