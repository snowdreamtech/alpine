{
  "name": "Snowdream Tech Universal Workspace",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "remoteUser": "root",
  "workspaceFolder": "/workspaces/template",
  "forwardPorts": [],
  "containerEnv": {
    "ENABLE_GITHUB_PROXY": "0",
    "MISE_QUIET": "0",
    "MISE_IGNORE_MISE_TOML": "1",
    "MISE_WARN_UNTRUSTED": "0",
    "HOST_HOME": "/host-home"
  },
  "onCreateCommand": "echo '⏳ Initializing Devcontainer...'",
  "postCreateCommand": "VERBOSE=1 sh /workspaces/template/.devcontainer/init.sh 2>&1 | tee /tmp/devcontainer-init.log",
  "postStartCommand": "echo '✅ Devcontainer is ready!'",
  "updateContentCommand": "make install",
  "waitFor": "postCreateCommand"
}
